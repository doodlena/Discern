{
  "manifest_version": 3,
  "name": "DISCERN - Credibility Checker",
  "version": "1.0.0",
  "description": "AI-powered credibility scoring for any webpage",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://discern-backend-tnxh.onrender.com/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}
