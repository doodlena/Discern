// Prisma Schema for DISCERN Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Analysis Model - Stores all credibility analyses
model Analysis {
  id              String   @id @default(cuid())
  contentType     String   // 'url', 'text', or 'pdf'
  contentHash     String   @unique // For caching duplicate requests
  originalContent String   @db.Text

  // Analysis Results (stored as JSONB)
  score           Int
  confidence      String
  summary         String   @db.Text
  citations       Json     // Array of citations
  factors         Json     // Scoring breakdown
  warnings        Json?    // Optional warnings
  processingSteps Json?    // For explainability mode

  // Metadata
  demoMode        Boolean  @default(false)
  explainability  Boolean  @default(false)
  processingTime  Int?     // milliseconds

  // Tracking
  ipAddress       String?
  userAgent       String?  @db.Text
  domain          String?  // Extracted domain for URL type

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contentHash])
  @@index([domain])
  @@index([createdAt])
  @@index([score])
}

// User Model - For admin and future user accounts
model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?
  isAdmin      Boolean  @default(false)

  // API Usage
  apiKey       String?  @unique

  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  @@index([email])
  @@index([apiKey])
}

// Analytics Cache - Pre-computed metrics for dashboard
model AnalyticsCache {
  id              String   @id @default(cuid())
  metricType      String   // 'daily', 'weekly', 'monthly'
  metricDate      DateTime

  totalAnalyses   Int      @default(0)
  averageScore    Float    @default(0)

  // Score Distribution
  lowScoreCount   Int      @default(0)   // 0-49
  mediumScoreCount Int     @default(0)   // 50-79
  highScoreCount  Int      @default(0)   // 80-100

  // Content Type Breakdown
  urlCount        Int      @default(0)
  textCount       Int      @default(0)
  pdfCount        Int      @default(0)

  // Top Domains (stored as JSON array)
  topDomains      Json?

  updatedAt       DateTime @updatedAt

  @@unique([metricType, metricDate])
  @@index([metricType])
  @@index([metricDate])
}

// Rate Limiting - Track API usage
model RateLimit {
  id          String   @id @default(cuid())
  identifier  String   // IP address or API key
  endpoint    String   // Which endpoint was called
  requestCount Int     @default(1)
  windowStart DateTime

  @@unique([identifier, endpoint, windowStart])
  @@index([identifier])
  @@index([windowStart])
}

// Demo Content - Cached results for demo mode
model DemoContent {
  id              String   @id @default(cuid())
  title           String
  url             String   @unique
  category        String   // 'news', 'science', 'opinion', 'misinformation'
  expectedScore   Int

  // Cached result (same structure as Analysis)
  cachedResult    Json

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
}

// User Feedback - Track satisfaction and comments
model Feedback {
  id          String   @id @default(cuid())
  analysisId  String   // Reference to Analysis (not enforced FK for flexibility)

  // Satisfaction rating
  thumbsUp    Boolean? // true = thumbs up, false = thumbs down, null = no rating

  // Open-ended feedback
  comment     String?  @db.Text

  // Tracking
  ipAddress   String?
  userAgent   String?  @db.Text

  createdAt   DateTime @default(now())

  @@index([analysisId])
  @@index([thumbsUp])
  @@index([createdAt])
}
